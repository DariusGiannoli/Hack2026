<!--
  Inspire Hand Right — MuJoCo MJCF
  Adapted from inspire_hand/inspire_hand_right.xml:
    - All worldbody content wrapped in a root body "inspire_palm"
    - freejoint "palm_free" on inspire_palm (for weld-based mocap control)
    - Position actuators for all 12 joints (kp=3.0 to match LEAP convention)
  Mesh files must be in the meshdir of the parent scene (assets/).
-->
<mujoco model="inspire_hand_right_body">
  <compiler angle="radian"/>

  <default>
    <joint damping="0.05" frictionloss="0.001" armature="0.001"/>
    <geom contype="1" conaffinity="1" condim="3" friction="1 0.01 0.001"/>
  </default>

  <asset>
    <mesh name="right_base_link"          file="right_base_link.obj"/>
    <mesh name="right_thumb_proximal_base" file="right_thumb_proximal_base.obj"/>
    <mesh name="right_thumb_proximal"      file="right_thumb_proximal.obj"/>
    <mesh name="right_thumb_intermediate"  file="right_thumb_intermediate.obj"/>
    <mesh name="right_thumb_distal"        file="right_thumb_distal.obj"/>
    <mesh name="right_index_proximal"      file="right_index_proximal.obj"/>
    <mesh name="right_index_intermediate"  file="right_index_intermediate.obj"/>
    <mesh name="right_middle_intermediate" file="right_middle_intermediate.obj"/>
    <mesh name="right_pinky_intermediate"  file="right_pinky_intermediate.obj"/>
  </asset>

  <worldbody>
    <!-- Root body: controlled by weld to hand_proxy mocap body -->
    <body name="inspire_palm" pos="0 0.3 0.3">
      <freejoint name="palm_free"/>

      <!-- Palm base: visual mesh + collision boxes -->
      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_base_link"/>
      <geom size="0.028 0.0139"            pos="0 -0.0136 0"  quat="0.707109 0.707105 0 0" type="cylinder"/>
      <geom size="0.01955 0.0101 0.0287"   pos="-0.0032 -0.038 0"   type="box"/>
      <geom size="0.01955 0.02 0.0407"     pos="-0.0032 -0.0682 0"  type="box"/>
      <geom size="0.0161 0.02 0.0407"      pos="0 -0.1081 0"        type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 0.0309"  type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 0.0118"  type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 -0.007"  type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 -0.0262" type="box"/>

      <!-- Thumb -->
      <body name="thumb_proximal_base" pos="-0.01696 -0.0691 -0.02045" quat="0.499998 0.5 -0.5 0.500002">
        <inertial pos="-0.0048064 0.0009382 -0.00757" quat="0.515015 0.680854 0.408023 0.323596"
                  mass="0.0018869" diaginertia="8.66026e-08 6.8732e-08 4.94194e-08"/>
        <joint name="thumb_proximal_yaw_joint"   pos="0 0 0" axis="0 0 -1" range="0 1.308" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_thumb_proximal_base"/>
        <geom type="mesh" mesh="right_thumb_proximal_base"/>

        <body name="thumb_proximal" pos="-0.0088099 0.010892 -0.00925" quat="0.0996843 0.0996847 0.700046 0.700044">
          <inertial pos="0.021932 0.012785 -0.0080386" quat="-0.254474 0.660716 0.251893 0.659733"
                    mass="0.0066075" diaginertia="2.78601e-06 2.43933e-06 8.64566e-07"/>
          <joint name="thumb_proximal_pitch_joint" pos="0 0 0" axis="0 0 1" range="0 0.6" actuatorfrcrange="-1 1"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_thumb_proximal"/>
          <geom type="mesh" mesh="right_thumb_proximal"/>

          <body name="thumb_intermediate" pos="0.04407 0.034553 -0.0008">
            <inertial pos="0.0095544 -0.0016282 -0.0071997" quat="0.636718 0.307389 -0.636802 0.307548"
                      mass="0.0037847" diaginertia="4.6531e-07 4.48089e-07 2.45661e-07"/>
            <joint name="thumb_intermediate_joint" pos="0 0 0" axis="0 0 1" range="0 0.8" actuatorfrcrange="-1 1"/>
            <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_thumb_intermediate"/>
            <geom type="mesh" mesh="right_thumb_intermediate"/>

            <body name="thumb_distal" pos="0.020248 0.010156 -0.0012">
              <inertial pos="0.0092888 0.0049529 -0.0060033" quat="-0.266294 0.655967 0.262806 0.655537"
                        mass="0.0033441" diaginertia="2.0026e-07 1.95247e-07 8.1593e-08"/>
              <joint name="thumb_distal_joint" pos="0 0 0" axis="0 0 1" range="0 0.4" actuatorfrcrange="-1 1"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_thumb_distal"/>
              <geom type="mesh" mesh="right_thumb_distal"/>
            </body>
          </body>
        </body>
      </body>

      <!-- Index finger -->
      <body name="index_proximal" pos="0.00028533 -0.13653 -0.032268" quat="0.0174454 -0.999848 0 0">
        <inertial pos="0.0012259 0.011942 -0.0060001" quat="0.50867 0.49121 -0.508643 0.491172"
                  mass="0.0042403" diaginertia="6.9398e-07 6.62871e-07 2.10909e-07"/>
        <joint name="index_proximal_joint" pos="0 0 0" axis="0 0 1" range="0 1.47" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_proximal"/>
        <geom type="mesh" mesh="right_index_proximal"/>

        <body name="index_intermediate" pos="-0.0026138 0.032026 -0.001">
          <inertial pos="0.0019697 0.019589 -0.005" quat="0.466773 0.531152 -0.466773 0.531153"
                    mass="0.0045683" diaginertia="7.8179e-07 7.72465e-07 8.47212e-08"/>
          <joint name="index_intermediate_joint" pos="0 0 0" axis="0 0 1" range="-0.04545 1.56" actuatorfrcrange="-1 1"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_intermediate"/>
          <geom type="mesh" mesh="right_index_intermediate"/>
        </body>
      </body>

      <!-- Middle finger -->
      <body name="middle_proximal" pos="0.00028533 -0.1371 -0.01295" quat="-3.67321e-06 -1 0 0">
        <inertial pos="0.001297 0.011934 -0.0060001" quat="0.510131 0.489693 -0.510105 0.489653"
                  mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="middle_proximal_joint" pos="0 0 0" axis="0 0 1" range="0 1.47" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_proximal"/>
        <geom type="mesh" mesh="right_index_proximal"/>

        <body name="middle_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.001921 0.020796 -0.005" quat="0.466148 0.531627 -0.466229 0.531705"
                    mass="0.0050396" diaginertia="9.8384e-07 9.73279e-07 9.14014e-08"/>
          <joint name="middle_intermediate_joint" pos="0 0 0" axis="0 0 1" range="-0.04545 1.56" actuatorfrcrange="-1 1"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_middle_intermediate"/>
          <geom type="mesh" mesh="right_middle_intermediate"/>
        </body>
      </body>

      <!-- Ring finger -->
      <body name="ring_proximal" pos="0.00028533 -0.13691 0.0062872" quat="0.0261933 0.999657 0 0">
        <inertial pos="0.001297 0.011934 -0.0060002" quat="0.510129 0.489691 -0.510107 0.489654"
                  mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="ring_proximal_joint" pos="0 0 0" axis="0 0 1" range="0 1.47" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_proximal"/>
        <geom type="mesh" mesh="right_index_proximal"/>

        <body name="ring_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.0021753 0.019567 -0.005" quat="0.469554 0.528695 -0.469554 0.528695"
                    mass="0.0045683" diaginertia="7.8177e-07 7.72448e-07 8.4722e-08"/>
          <joint name="ring_intermediate_joint" pos="0 0 0" axis="0 0 1" range="-0.04545 1.56" actuatorfrcrange="-1 1"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_intermediate"/>
          <geom type="mesh" mesh="right_index_intermediate"/>
        </body>
      </body>

      <!-- Pinky finger -->
      <body name="pinky_proximal" pos="0.00028533 -0.13571 0.025488" quat="0.0523224 0.99863 0 0">
        <inertial pos="0.001297 0.011934 -0.0060001" quat="0.51013 0.489693 -0.510106 0.489653"
                  mass="0.0042403" diaginertia="6.9397e-07 6.62865e-07 2.10915e-07"/>
        <joint name="pinky_proximal_joint" pos="0 0 0" axis="0 0 1" range="0 1.47" actuatorfrcrange="-1 1"/>
        <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_index_proximal"/>
        <geom type="mesh" mesh="right_index_proximal"/>

        <body name="pinky_intermediate" pos="-0.0024229 0.032041 -0.001">
          <inertial pos="0.0024748 0.016203 -0.0050031" quat="0.47398 0.528862 -0.469291 0.524799"
                    mass="0.0035996" diaginertia="4.4867e-07 4.43723e-07 6.56538e-08"/>
          <joint name="pinky_intermediate_joint" pos="0 0 0" axis="0 0 1" range="-0.04545 1.56" actuatorfrcrange="-1 1"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="right_pinky_intermediate"/>
          <geom type="mesh" mesh="right_pinky_intermediate"/>
        </body>
      </body>

    </body>  <!-- inspire_palm -->
  </worldbody>

  <!--
    12 position actuators — order must match IKRetargeter.retarget() output:
      [0]  thumb_proximal_yaw_joint
      [1]  thumb_proximal_pitch_joint
      [2]  thumb_intermediate_joint
      [3]  thumb_distal_joint
      [4]  index_proximal_joint
      [5]  index_intermediate_joint
      [6]  middle_proximal_joint
      [7]  middle_intermediate_joint
      [8]  ring_proximal_joint
      [9]  ring_intermediate_joint
      [10] pinky_proximal_joint
      [11] pinky_intermediate_joint
  -->
  <actuator>
    <!-- ctrlrange doit correspondre exactement au range du joint associé -->
    <position name="th_yaw_act"   joint="thumb_proximal_yaw_joint"   kp="3.0" kv="0.01" ctrlrange="0 1.308"/>
    <position name="th_pitch_act" joint="thumb_proximal_pitch_joint"  kp="3.0" kv="0.01" ctrlrange="0 0.6"/>
    <position name="th_int_act"   joint="thumb_intermediate_joint"    kp="3.0" kv="0.01" ctrlrange="0 0.8"/>
    <position name="th_dis_act"   joint="thumb_distal_joint"          kp="3.0" kv="0.01" ctrlrange="0 0.4"/>

    <position name="if_prx_act"  joint="index_proximal_joint"        kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="if_int_act"  joint="index_intermediate_joint"    kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>

    <position name="mf_prx_act"  joint="middle_proximal_joint"       kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="mf_int_act"  joint="middle_intermediate_joint"   kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>

    <position name="rf_prx_act"  joint="ring_proximal_joint"         kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="rf_int_act"  joint="ring_intermediate_joint"     kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>

    <position name="pk_prx_act"  joint="pinky_proximal_joint"        kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="pk_int_act"  joint="pinky_intermediate_joint"    kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>
  </actuator>

</mujoco>
