<mujoco model="teleop_humanoid_only">
  <compiler meshdir="./assets/"/>
  <include file="humanoid.xml"/>

  <statistic center="0 0.3 0.3" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <worldbody>
    <light directional="true" diffuse=".5 .5 .5" specular="0.1 0.1 0.1"
           pos="0 0 1.5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="1 1 1" rgba="0.2 0.3 0.4 1"/>

    <!-- Cible IK (main droite) — point de référence visuel uniquement -->
    <body name="hand_proxy" mocap="true" pos="0 0.3 0.3">
      <geom type="sphere" size="0.012" rgba="1 0.3 0 0.6"
            contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
