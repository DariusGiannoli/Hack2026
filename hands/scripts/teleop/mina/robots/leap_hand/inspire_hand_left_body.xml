  <actuator>
    <position name="l_th_yaw_act"   joint="l_thumb_proximal_yaw_joint"   kp="3.0" kv="0.01" ctrlrange="0 1.308"/>
    <position name="l_th_pitch_act" joint="l_thumb_proximal_pitch_joint"  kp="3.0" kv="0.01" ctrlrange="0 0.6"/>
    <position name="l_th_int_act"   joint="l_thumb_intermediate_joint"    kp="3.0" kv="0.01" ctrlrange="0 0.8"/>
    <position name="l_th_dis_act"   joint="l_thumb_distal_joint"          kp="3.0" kv="0.01" ctrlrange="0 0.4"/>

    <position name="l_if_prx_act"   joint="l_index_proximal_joint"        kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="l_if_int_act"   joint="l_index_intermediate_joint"    kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>

    <position name="l_mf_prx_act"   joint="l_middle_proximal_joint"       kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
    <position name="l_mf_int_act"   joint="l_middle_intermediate_joint"   kp="3.0" kv="0.01" ctrlrange="-0.04545 1.56"/>

    <position name="l_rf_prx_act"   joint="l_ring_proximal_joint"         kp="3.0" kv="0.01" ctrlrange="0 1.47"/>
