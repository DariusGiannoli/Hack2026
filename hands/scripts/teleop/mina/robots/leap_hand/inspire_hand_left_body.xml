<!--
  Inspire Hand Left — MuJoCo MJCF
  All body/joint/actuator names prefixed with "l_" to avoid conflicts with right hand.
  Root body "inspire_palm_l" with freejoint "palm_free_l" for weld-based mocap control.
  Actuator order (indices 12..23 when included after right hand):
    [0]  l_th_yaw_act    thumb_proximal_yaw_joint
    [1]  l_th_pitch_act  thumb_proximal_pitch_joint
    [2]  l_th_int_act    thumb_intermediate_joint
    [3]  l_th_dis_act    thumb_distal_joint
    [4]  l_if_prx_act    index_proximal_joint
    [5]  l_if_int_act    index_intermediate_joint
    [6]  l_mf_prx_act    middle_proximal_joint
    [7]  l_mf_int_act    middle_intermediate_joint
    [8]  l_rf_prx_act    ring_proximal_joint
    [9]  l_rf_int_act    ring_intermediate_joint
    [10] l_pk_prx_act    pinky_proximal_joint
    [11] l_pk_int_act    pinky_intermediate_joint
-->
<mujoco model="inspire_hand_left_body">
  <compiler angle="radian"/>

  <default>
    <joint damping="0.05" frictionloss="0.001" armature="0.001"/>
    <geom contype="1" conaffinity="1" condim="3" friction="1 0.01 0.001"/>
  </default>

  <asset>
    <mesh name="left_base_link"           file="left_base_link.obj"/>
    <mesh name="left_thumb_proximal_base" file="left_thumb_proximal_base.obj"/>
    <mesh name="left_thumb_proximal"      file="left_thumb_proximal.obj"/>
    <mesh name="left_thumb_intermediate"  file="left_thumb_intermediate.obj"/>
    <mesh name="left_thumb_distal"        file="left_thumb_distal.obj"/>
    <mesh name="left_index_proximal"      file="left_index_proximal.obj"/>
    <mesh name="left_index_intermediate"  file="left_index_intermediate.obj"/>
    <mesh name="left_middle_intermediate" file="left_middle_intermediate.obj"/>
    <mesh name="left_pinky_intermediate"  file="left_pinky_intermediate.obj"/>
  </asset>

  <worldbody>
    <body name="inspire_palm_l" pos="0 0.3 0.3">
      <freejoint name="palm_free_l"/>

      <geom type="mesh" contype="0" conaffinity="0" group="1" density="0" mesh="left_base_link"/>
      <geom size="0.028 0.0139"            pos="0 -0.0136 0"         quat="0.707109 0.707105 0 0" type="cylinder"/>
      <geom size="0.01955 0.0101 0.0287"   pos="-0.0032 -0.038 0"    type="box"/>
      <geom size="0.01955 0.02 0.0407"     pos="-0.0032 -0.0682 0"   type="box"/>
      <geom size="0.0161 0.02 0.0407"      pos="0 -0.1081 0"         type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 -0.0309" type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 -0.0118" type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 0.007"   type="box"/>
      <geom size="0.00625 0.00555 0.00445" pos="-0.0016 -0.134 0.0262"  type="box"/>

      <!-- Thumb -->
      <body name="l_thumb_proximal_base" pos="-0.01696 -0.0691 0.02045" quat="0.499998 0.5 -0.5 0.500002">
        <inertial pos="0.0048817 0.0009382 -0.00722" quat="0.408023 0.323596 0.515015 0.680854"
