      <!-- Ring finger -->
      <body name="l_ring_proximal" pos="0.00028533 -0.13691 -0.0062872" quat="0.999657 0.026177 0 0">
        <inertial pos="0.001297 -0.011934 -0.0060002" quat="0.489691 0.510129 -0.489654 0.510107"
