      </body>

      <!-- Index finger -->
      <body name="l_index_proximal" pos="0.00028533 -0.13653 0.032268" quat="0.999848 -0.0174526 0 0">
        <inertial pos="0.0012259 -0.011942 -0.0060001" quat="0.49121 0.50867 -0.491172 0.508643"
                  mass="0.0042403" diaginertia="6.9398e-07 6.62871e-07 2.10909e-07"/>
        <joint name="l_index_proximal_joint" pos="0 0 0" axis="0 0 -1" range="0 1.47" actuatorfrcrange="-1 1"/>
