        <geom type="mesh" mesh="left_thumb_proximal_base"/>

        <body name="l_thumb_proximal" pos="0.0099867 0.0098242 -0.0089" quat="0.704571 -0.704573 -0.0598169 0.0598167">
          <inertial pos="0.021932 -0.012785 -0.0080386" quat="0.254474 0.660716 -0.251893 0.659733"
